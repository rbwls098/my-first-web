# Book Project .gitignore
# docs/, practice/, 강의계획서.md 만 원격에 업로드

# 루트의 모든 항목 무시
/*

# 추적할 항목만 허용
!.gitignore
!/docs/
!/practice/
!/강의계획서.md

# ===================
# Python
# ===================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
venv/
ENV/
env/
.venv/

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints/

# ===================
# Node.js
# ===================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# ===================
# IDE
# ===================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# ===================
# OS
# ===================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ===================
# MS Office
# ===================
~$*.docx
~$*.xlsx
~$*.pptx
*.tmp

# ===================
# 프로젝트 특정
# ===================

# C회차 강사용 문서 (수강생 공개 제외)
docs/ch*C.md

# 출력 파일 (Word 변환 결과)
ms-word/output/*.docx
ms-word/output/*.pdf

# 대용량 데이터 파일
practice/**/data/*.csv
practice/**/data/*.xlsx
practice/**/data/*.json
practice/**/data/*.parquet
practice/**/data/*.pkl

# 모델 체크포인트
practice/**/code/*.h5
practice/**/code/*.pt
practice/**/code/*.pth
practice/**/code/*.pkl
practice/**/code/*.joblib
practice/**/code/checkpoints/

# 로그 파일
*.log
logs/

# 캐시
.cache/
*.temp

# ===================
# 보안
# ===================
.env
.env.local
config/secrets.yaml
*_secret.json
credentials.json
*api_key*
*API_KEY*

# ===================
# 압축 파일
# ===================
*.zip
*.tar.gz
*.rar

# ===================
# 아카이브 (이전 버전)
# ===================
_archive/

# ===================
# 유지할 파일
# ===================
!**/README.md
!**/.gitkeep
!ms-word/templates/*.md

# docs chapter C 파일 제외
docs/ch*C.md
